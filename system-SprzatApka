                            <div style="color: var(--text-muted); margin-bottom: 5px;">Ostatnie notatki</div>
                            <strong>AbcChaosu</strong>
                            <div style="color: var(--text-muted); font-size: 11px;">Możesz korzystać z Wi-Fi</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
