
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SprzatApka by AlPocket - Twoje biuro sprzątające w kieszeni</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0d0b18;
            --bg-card: #151226;
            --primary: #ff5e7e;
            --text-main: #ffffff;
            --text-muted: #8e8a9f;
            --accent-green: #00bfa5;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-dark);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Header */
        header {
            padding: 20px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .nav-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: var(--text-main);
        }

        .logo span {
            color: var(--primary);
        }

        /* Hero Section */
        .hero {
            padding: 80px 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 40px;
        }

        .hero-text {
            flex: 1;
            max-width: 600px;
        }

        .hero-text h1 {
            font-size: 48px;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 20px;
        }

        .hero-text h1 span {
            color: var(--primary);
        }

        .hero-text p {
            font-size: 18px;
            color: var(--text-muted);
            margin-bottom: 30px;
        }

        .cta-btn {
            display: inline-block;
            background-color: var(--primary);
            color: white;
            text-decoration: none;
            padding: 15px 35px;
            border-radius: 30px;
            font-weight: 600;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 4px 15px rgba(255, 94, 126, 0.3);
        }

        .cta-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(255, 94, 126, 0.5);
        }

        .hero-mockup {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }

        /* Mockup telefonu w CSS */
        .phone-frame {
            width: 300px;
            height: 600px;
            background: #000;
            border: 12px solid #252238;
            border-radius: 40px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7);
            overflow: hidden;
            position: relative;
        }

        .phone-screen {
            width: 100%;
            height: 100%;
            background-color: var(--bg-dark);
            display: flex;
            flex-direction: column;
            padding: 20px;
        }

        /* Elementy aplikacji wewnątrz makiety */
        .app-header {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .app-header strong {
            color: white;
            display: block;
            font-size: 20px;
        }

        .app-card {
            background: var(--bg-card);
            border-radius: 16px;
            padding: 15px;
            margin-bottom: 15px;
            border: 1px solid rgba(255, 255, 255, 0.03);
        }

        .app-card.sos {
            background: rgba(235, 87, 87, 0.1);
            border: 1px solid rgba(235, 87, 87, 0.3);
            color: #eb5757;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sos-badge {
            background: #eb5757;
            color: white;
            padding: 4px 8px;
            border-radius: 6px;
            font-weight: 700;
            font-size: 12px;
        }

        .app-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .grid-item {
            background: var(--bg-card);
            border-radius: 12px;
            padding: 12px;
            font-size: 13px;
        }

        .grid-item span {
            display: block;
            color: var(--text-muted);
            font-size: 11px;
            margin-top: 4px;
        }

        /* Features Section */
        .features {
            padding: 80px 0;
            background: rgba(21, 18, 38, 0.5);
        }

        .section-title {
            text-align: center;
            font-size: 36px;
            margin-bottom: 50px;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
        }

        .feature-box {
            background: var(--bg-card);
            padding: 30px;
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.02);
            transition: transform 0.3s;
        }

        .feature-box:hover {
            transform: translateY(-5px);
        }

        .feature-box h3 {
            font-size: 20px;
            margin-bottom: 15px;
            color: var(--primary);
        }

        .feature-box p {
            color: var(--text-muted);
            font-size: 15px;
        }

        /* Footer */
        footer {
            padding: 40px 0;
            text-align: center;
            color: var(--text-muted);
            font-size: 14px;
            border-top: 1px solid rgba(255, 255, 255, 0.05);
        }

        /* Responsywność */
        @media (max-width: 768px) {
            .hero {
                flex-direction: column;
                text-align: center;
                padding: 40px 0;
            }
            .hero-text h1 {
                font-size: 36px;
            }
            .hero-text {
                max-width: 100%;
            }
        }
    </style>
</head>
<body>

